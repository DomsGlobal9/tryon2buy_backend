datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

// ─── 1. MERCHANT (who sells clothes) ───
model Vendor {
  id                  String     @id @default(uuid())
  email               String     @unique
  passwordHash        String     @default("") @map("password_hash")
  name                String?
  storeName           String?    @map("store_name")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  drapeCredits        Int        @default(10) @map("drape_credits")
  userTryonCredits    Int        @default(10) @map("user_tryon_credits")
  bgChangeCredits     Int        @default(10) @map("bg_change_credits")
  blouseChangeCredits Int        @default(10) @map("blouse_change_credits")
  isUnlimited         Boolean    @default(false) @map("is_unlimited")

  garments            Garment[]
  assets              Asset[]

  @@map("tryon_vendors")
}

// ─── 2. CUSTOMER (who tries on clothes) ───
model Customer {
  id           String     @id @default(uuid())
  email        String?    @unique
  name         String     @default("")
  phone        String     @unique @default("")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  tryonCredits Int        @default(1) @map("tryon_credits")
  isUnlimited  Boolean    @default(false) @map("is_unlimited")

  assets       Asset[]

  @@map("tryon_customers")
}

// ─── 3. GARMENT (the clothing item in catalog) ───
model Garment {
  id          String    @id @default(uuid())
  vendorId    String    @map("vendor_id")
  vendor      Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  label       String?
  category    String?   // SAREE, LEHANGA, ANARKALI, KURTHI, SHARARA
  status      String    @default("PENDING") // PENDING | READY | FAILED
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  assets      Asset[]

  @@map("tryon_garments")
}

// ─── 4. ASSET (Every image generated or uploaded) ───
model Asset {
  id                 String   @id @default(uuid())
  vendorId           String?  @map("vendor_id")
  vendor             Vendor?  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  customerId         String?  @map("customer_id")
  customer           Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  garmentId          String?  @map("garment_id")
  garment            Garment? @relation(fields: [garmentId], references: [id], onDelete: Cascade)
  
  imageUrl           String   @map("image_url")
  assetType          String   // "GARMENT_FLAT", "HUMAN_MODEL", "TRYON_RESULT", "BG_SWAP_RESULT", "OUTFIT_MOD_RESULT"
  status             String   @default("READY")
  metadata           Json?    // Used for storing AI processing errors, model versions, etc.

  createdAt          DateTime @default(now()) @map("created_at")

  // The true power: Infinite Chaining
  parentRelations    AssetRelation[] @relation("ChildAsset")
  childRelations     AssetRelation[] @relation("ParentAsset")

  @@map("tryon_assets")
}

// ─── 5. ASSET RELATION (The action that connects two images) ───
model AssetRelation {
  id                 String   @id @default(uuid())
  parentAssetId      String   @map("parent_asset_id")
  childAssetId       String   @map("child_asset_id")
  action             String   // "DRAPED", "BG_SWAP", "BLOUSE_EDIT"
  
  promptUsed         String?  @map("prompt_used") @db.Text
  processingTimeMs   Int?     @map("processing_time_ms")
  createdAt          DateTime @default(now()) @map("created_at")
  
  parentAsset        Asset    @relation("ParentAsset", fields: [parentAssetId], references: [id], onDelete: Cascade)
  childAsset         Asset    @relation("ChildAsset", fields: [childAssetId], references: [id], onDelete: Cascade)

  @@map("tryon_asset_relations")
}

// ─── 6. GUEST LIMITS (unauthenticated users) ───
model GuestLimit {
  id         String   @id @default(uuid())
  ipAddress  String   @unique @map("ip_address")
  tryonCount Int      @default(0) @map("tryon_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("tryon_guest_limits")
}
